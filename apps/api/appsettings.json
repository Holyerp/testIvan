{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Jwt": {
    "Issuer": "pinoles-api",
    "Audience": "pinoles-web",
    "AccessTokenExpiryMinutes": 480,
    "RefreshTokenExpiryDays": 7
  },
  "Cache": {
    "DefaultTtlMinutes": 5
  }
}
